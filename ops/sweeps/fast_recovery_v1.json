{
  "description": "Fast recovery sweep for AEGIS PPO. Uses short training windows with held-out eval suite expansion.",
  "runs": [
    {
      "label": "baseline_short",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {}
    },
    {
      "label": "explore_more",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "entropy_coeff": 0.015,
        "clip_param": 0.22
      }
    },
    {
      "label": "explore_less_fast",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "lr": 0.00025,
        "entropy_coeff": 0.008
      }
    },
    {
      "label": "larger_batch",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "train_batch_size": 8192,
        "minibatch_size": 1024
      }
    },
    {
      "label": "damage_guardrail",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "env_config": {
          "reward_weights": {
            "exfiltration_penalty_mult": 5.5,
            "newly_compromised_penalty_mult": 1.3,
            "persistent_compromise_penalty_per_step": 0.1
          }
        }
      }
    },
    {
      "label": "latency_push",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "env_config": {
          "reward_weights": {
            "early_detection_bonus_mult": 1.2,
            "undetected_compromise_penalty_per_step": 0.16,
            "passive_monitor_under_attack_penalty": 0.22
          }
        }
      }
    },
    {
      "label": "assertive_containment",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "env_config": {
          "reward_weights": {
            "isolation_downstream_mult": 1.2,
            "exfil_prevent_bonus": 2.0,
            "benign_isolation_penalty_mult": 0.2
          }
        }
      }
    },
    {
      "label": "low_lr_stable",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "lr": 0.0002,
        "train_batch_size": 8192
      }
    },
    {
      "label": "high_lr_recovery",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "lr": 0.00035,
        "clip_param": 0.25
      }
    },
    {
      "label": "action_cost_relax",
      "train_timesteps": 250000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "env_config": {
          "reward_weights": {
            "action_cost_scale": 0.55,
            "availability_drop_penalty_mult": 0.5
          }
        }
      }
    },
    {
      "label": "model_capacity_plus",
      "train_timesteps": 300000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "model": {
          "custom_model": "aegis_blue_net",
          "custom_model_config": {
            "node_embed_dim": 96,
            "global_embed_dim": 48,
            "gnn_layers": 3,
            "lstm_hidden": 160,
            "fc_hiddens": [
              320,
              160
            ]
          }
        }
      }
    },
    {
      "label": "balanced_longer",
      "train_timesteps": 350000,
      "seeds_per_scenario": 4,
      "seed_start": 2001,
      "overrides": {
        "lr": 0.00025,
        "entropy_coeff": 0.01,
        "train_batch_size": 8192,
        "minibatch_size": 1024,
        "env_config": {
          "reward_weights": {
            "early_detection_bonus_mult": 1.0,
            "exfiltration_penalty_mult": 5.0,
            "undetected_compromise_penalty_per_step": 0.15,
            "action_cost_scale": 0.65
          }
        }
      }
    }
  ]
}
